# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
.env
.env.*
!.env.example
.secrets/

# Pytest / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Editors / OS
.DS_Store
*.swp
*.swo

# Claude / tooling scratch
.claude/scheduled_tasks.lock

# Playwright MCP screenshots (but keep README)
.playwright-mcp/
!.playwright-mcp/README.md

# Ad-hoc preview screenshots and recordings dropped at the repo root
# (the `/` prefix scopes this to the root only, so legitimate UI
# assets under mocks/app/static/, docs/, or /record-demo GIFs under
# their documented paths are *not* affected).
/*.png
/*.jpg
/*.jpeg
/*.gif
/*.webp
/*.mp4
/*.webm

# bv (beads viewer) local config and caches
.bv/

# Local runtime data (SQLite DBs, etc.)
/data/
