# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
.env
.env.*
!.env.example
.secrets/

# Pytest / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Cross-process flock used by tests/boundary/test_import_gate.py to
# serialise the two parallel ``lint-imports`` invocations under
# pytest-xdist (see the module docstring for the why).
.pytest-import-gate.lock

# Editors / OS
.DS_Store
*.swp
*.swo

# Claude / tooling scratch
.claude/scheduled_tasks.lock

# Playwright MCP screenshots (but keep README)
.playwright-mcp/
!.playwright-mcp/README.md

# Ad-hoc preview screenshots and recordings dropped at the repo root
# (the `/` prefix scopes this to the root only, so legitimate UI
# assets under mocks/app/static/, docs/, or /record-demo GIFs under
# their documented paths are *not* affected).
/*.png
/*.jpg
/*.jpeg
/*.gif
/*.webp
/*.mp4
/*.webm

# bv (beads viewer) local config and caches
.bv/

# Local runtime data (SQLite DBs, etc.)
/data/

# git-of-theseus intermediate data (regenerated by scripts/update-loc-chart.sh)
.loc-stats/
!docs/loc-by-language.svg

# Playwright e2e diff captures + tracing artefacts (cd-ndmv).
# ``_baselines/`` is committed (the visual-regression source of
# truth); ``_diff/`` and ``_artifacts/`` are the per-run output the
# walker / pytest-playwright drop on failure. Keep the directory
# stub via ``.gitkeep`` so a ``ls`` after ``git clean`` still
# resolves; ignore everything else inside.
tests/e2e/_diff/*
!tests/e2e/_diff/.gitkeep
tests/e2e/_artifacts/
