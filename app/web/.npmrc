# npm 11+ enforces peer-dep ranges strictly. `vite-plugin-pwa@1.2.0`
# peers `vite@^3..^7`, but the toolchain we mirror from `mocks/web/`
# declares `vite@^8.0.8` + `@vitejs/plugin-react@^6.0.1` (which peers
# `vite@^8`). Without this flag, `npm ci` aborts with ERESOLVE before
# it ever writes node_modules. Root fix (realign mocks' declared
# versions with the actually-installed Rollup 4 / Vite 5 set, or wait
# for a `vite-plugin-pwa` release that peers vite 8) is tracked under
# cd-gv9p; until then this file keeps the scaffold installable.
legacy-peer-deps=true
