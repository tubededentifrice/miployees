# crew.day — environment variable template.
# Copy to `.env` (gitignored) and fill in the blanks for local dev.
# See app/config.py and docs/specs/16-deployment-operations.md
# §"Environment variables".

# --- Required ---
CREWDAY_DATABASE_URL=sqlite+aiosqlite:///data/crewday.db

# --- Bind guard (see docs/specs/01 §"Runtime invariants" and §16) ---
CREWDAY_BIND_HOST=127.0.0.1
CREWDAY_BIND_PORT=8000
# Comma-separated fnmatch globs; set value replaces the default.
CREWDAY_TRUSTED_INTERFACES=tailscale*
CREWDAY_ALLOW_PUBLIC_BIND=0

# --- Paths ---
CREWDAY_DATA_DIR=./data

# --- Public URL (optional until TLS terminates externally) ---
# CREWDAY_PUBLIC_URL=https://ops.example.com

# --- WebAuthn (optional override; derived from CREWDAY_PUBLIC_URL otherwise) ---
# Set only when the rp_id should differ from the origin's hostname —
# e.g. host on `app.example.com` but scope passkeys to `example.com` so
# they work on sibling subdomains too. See docs/specs/03 §WebAuthn.
# CREWDAY_WEBAUTHN_RP_ID=example.com

# --- SMTP (optional; see §10 messaging-notifications) ---
# CREWDAY_SMTP_HOST=smtp.example.com
# CREWDAY_SMTP_PORT=587
# CREWDAY_SMTP_USER=noreply@example.com
# CREWDAY_SMTP_PASSWORD=
# Envelope sender for every outbound message.
# CREWDAY_SMTP_FROM=crew.day <noreply@example.com>
# STARTTLS (587) / implicit TLS (465); flip off only behind a trusted relay.
# CREWDAY_SMTP_USE_TLS=1
# Socket timeout (seconds) for SMTP I/O.
# CREWDAY_SMTP_TIMEOUT=10
# Domain for the Return-Path ``bounce+<token>@<domain>``. Defaults to
# the domain parsed from CREWDAY_SMTP_FROM if unset.
# CREWDAY_SMTP_BOUNCE_DOMAIN=example.com

# --- LLM (optional; see §11 llm-and-agents) ---
# CREWDAY_OPENROUTER_API_KEY=

# --- Signing / tokens (required in production; auto-generated in dev) ---
# CREWDAY_ROOT_KEY=

# --- Runtime ---
CREWDAY_DEMO_MODE=0
CREWDAY_WORKER=internal
CREWDAY_STORAGE_BACKEND=localfs

# --- Frontend seam (cd-q1be) ---
# ``prod`` serves the built SPA from ``app/web/dist`` with a catch-all
# that returns ``index.html`` for non-API GETs. ``dev`` proxies those
# GETs to a running Vite dev server at CREWDAY_VITE_DEV_URL so HMR
# keeps working while editing app/web/src/. Prod is the default and
# is what every self-hosted / SaaS box runs.
CREWDAY_PROFILE=prod
# CREWDAY_VITE_DEV_URL=http://127.0.0.1:5173
